# Stored per machine at ~/.config/numados/obsidian/profiles/<name>.env.
# Keep machine paths and credentials out of project repositories.
NUMADOS_OBSIDIAN_VAULT=/absolute/path/to/your/obsidian-vault
NUMADOS_OBSIDIAN_WRITE_ROOT=
NUMADOS_OBSIDIAN_SEARCH_ROOTS=
NUMADOS_OBSIDIAN_SEARCH_BACKEND=auto
NUMADOS_OBSIDIAN_QMD_COLLECTION=
NUMADOS_OBSIDIAN_LINK_STYLE=preserve
