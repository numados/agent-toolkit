{
  "schema_version": 1,
  "harness": "pi",
  "tested_client": {
    "pi": "0.80.3",
    "pi_subagents": "0.13.0"
  },
  "orchestrator": {
    "provider": "zai-coding-cn",
    "model": "glm-5.2",
    "thinking": "xhigh"
  },
  "agents": {
    "scout": {
      "role": "read-only collection and extraction",
      "model": "deepseek/deepseek-v4-flash",
      "thinking": "low",
      "tools": ["read", "grep", "find", "ls"]
    },
    "worker": {
      "role": "small, well-defined implementation",
      "model": "deepseek/deepseek-v4-flash",
      "thinking": "low"
    },
    "worker-glm": {
      "role": "complex implementation with an approved plan",
      "model": "zai-coding-cn/glm-5.2",
      "thinking": "high"
    },
    "planner": {
      "role": "implementation planning",
      "model": "zai-coding-cn/glm-5.2",
      "thinking": "xhigh",
      "tools": ["read", "grep", "find", "ls"]
    },
    "reviewer": {
      "role": "independent code review",
      "model": "zai-coding-cn/glm-5.2",
      "thinking": "xhigh",
      "tools": ["read", "grep", "find", "ls", "bash"]
    }
  },
  "external_tools": {
    "agy": {
      "model": "Gemini 3.5 Flash (High)",
      "selection": "fixed"
    },
    "claude_btcs": {
      "model": "claude-opus-4-8[1m]",
      "effort_by_class": {
        "light": "low",
        "complex": "high"
      }
    },
    "codex": {
      "light": {
        "model": "gpt-5.6-luna",
        "reasoning_effort": "max",
        "approval_policy": "never",
        "sandbox": "read-only"
      },
      "complex": {
        "model": "gpt-5.6-sol",
        "reasoning_effort": "high",
        "approval_policy": "never",
        "sandbox": "workspace-write"
      }
    }
  }
}
